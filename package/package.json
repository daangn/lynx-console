{
  "name": "lynx-console",
  "version": "0.3.1",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./setup": {
      "types": "./dist/setup.d.mts",
      "import": "./dist/setup.mjs",
      "require": "./dist/setup.cjs"
    }
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "devDependencies": {
    "@lynx-js/react": "^0.116.0",
    "@lynx-js/types": "^3.7.0",
    "@types/react": "^18.3.28",
    "react": "^18.3.1",
    "tsdown": "^0.20.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@lynx-js/react": "^0.110.0",
    "@lynx-js/types": "^3.6.0",
    "@types/react": "^18"
  },
  "dependencies": {
    "devalue": "^5.6.4",
    "javascript-stringify": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/daangn/lynx-console"
  },
  "publishConfig": {
    "provenance": true
  }
}
